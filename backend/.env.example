# Copy this file to .env and fill in your values

# Required for the AI features (Ask Signal, explanations, win-back emails)
OPENAI_API_KEY=your-openai-key-here
# Model to use (gpt-4o-mini is cheap and great for this; gpt-4.1-nano is even cheaper)
OPENAI_MODEL=gpt-4o-mini

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/retention

# Optional
# PORT=3001
# RATE_MAX=15            # max AI requests per IP per minute
# RATE_WINDOW_MS=60000
